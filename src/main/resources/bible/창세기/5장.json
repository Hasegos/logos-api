[
  {"book":"창세기","chapter":"5","verse":"1","text":"이것은 아담의 계보를 적은 책이니라 하나님이 사람을 창조하실 때에 하나님의 모양대로 지으시되"},
  {"book":"창세기","chapter":"5","verse":"2","text":"남자와 여자를 창조하셨고 그들이 창조되던 날에 하나님이 그들에게 복을 주시고 그들의 이름을 사람이라 일컬으셨더라"},
  {"book":"창세기","chapter":"5","verse":"3","text":"아담은 백삼십 세에 자기의 모양 곧 자기의 형상과 같은 아들을 낳아 이름을 셋이라 하였고"},
  {"book":"창세기","chapter":"5","verse":"4","text":"아담은 셋을 낳은 후 팔백 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"5","text":"그는 구백삼십 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"6","text":"셋은 백오 세에 에노스를 낳았고"},
  {"book":"창세기","chapter":"5","verse":"7","text":"에노스를 낳은 후 팔백칠 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"8","text":"그는 구백십이 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"9","text":"에노스는 구십 세에 게난을 낳았고"},
  {"book":"창세기","chapter":"5","verse":"10","text":"게난을 낳은 후 팔백십오 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"11","text":"그는 구백오 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"12","text":"게난은 칠십 세에 마할랄렐을 낳았고"},
  {"book":"창세기","chapter":"5","verse":"13","text":"마할랄렐을 낳은 후 팔백사십 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"14","text":"그는 구백십 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"15","text":"마할랄렐은 육십오 세에 야렛을 낳았고"},
  {"book":"창세기","chapter":"5","verse":"16","text":"야렛을 낳은 후 팔백삼십 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"17","text":"그는 팔백구십오 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"18","text":"야렛은 백육십이 세에 에녹을 낳았고"},
  {"book":"창세기","chapter":"5","verse":"19","text":"에녹을 낳은 후 팔백 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"20","text":"그는 구백육십이 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"21","text":"에녹은 육십오 세에 므두셀라를 낳았고"},
  {"book":"창세기","chapter":"5","verse":"22","text":"므두셀라를 낳은 후 삼백 년을 하나님과 동행하며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"23","text":"그는 삼백육십오 세를 살았더라"},
  {"book":"창세기","chapter":"5","verse":"24","text":"에녹이 하나님과 동행하더니 하나님이 그를 데려가시므로 세상에 있지 아니하였더라"},
  {"book":"창세기","chapter":"5","verse":"25","text":"므두셀라는 백팔십칠 세에 라멕을 낳았고"},
  {"book":"창세기","chapter":"5","verse":"26","text":"라멕을 낳은 후 칠백팔십이 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"27","text":"그는 구백육십구 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"28","text":"라멕은 백팔십이 세에 아들을 낳고"},
  {"book":"창세기","chapter":"5","verse":"29","text":"이름을 노아라 하여 이르되 여호와께서 땅을 저주하시므로 수고롭게 일하는 우리를 이 아들이 안위하리라 하였더라"},
  {"book":"창세기","chapter":"5","verse":"30","text":"라멕은 노아를 낳은 후 오백구십오 년을 지내며 자녀들을 낳았으며"},
  {"book":"창세기","chapter":"5","verse":"31","text":"그는 칠백칠십칠 세를 살고 죽었더라"},
  {"book":"창세기","chapter":"5","verse":"32","text":"노아는 오백 세 된 후에 셈과 함과 야벳을 낳았더라"}
]